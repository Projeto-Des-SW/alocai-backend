{
  "version": 2,
  "buildCommand": "./build.sh",
  "outputDirectory": "staticfiles",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@6.23.0",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}